{
  "name": "assistant",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "bun node_modules/electrobun/bin/electrobun.cjs dev",
    "dev": "bun node_modules/electrobun/bin/electrobun.cjs dev --watch",
    "build": "bun node_modules/electrobun/bin/electrobun.cjs build",
    "build:win": "bun run build -- --env=stable",
    "package:win": "powershell -ExecutionPolicy Bypass -File scripts/build-windows-installer.ps1"
  },
  "dependencies": {
    "electrobun": "^1.15.1"
  }
}
